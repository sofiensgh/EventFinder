@{
    ViewData["Title"] = "Access Denied";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full text-center">
        <div class="bg-gray-800 rounded-2xl shadow-2xl p-12 border border-gray-700">
            <i class="fas fa-lock text-red-500 text-6xl mb-6"></i>
            <h1 class="text-4xl font-bold text-white mb-4">Access Denied</h1>
            <p class="text-gray-400 mb-8">
                You do not have permission to access this page.
            </p>
            <div class="space-y-4">
                <a asp-controller="Home" asp-action="Index" 
                   class="block bg-gradient-to-r from-blue-600 to-purple-600 text-white px-6 py-3 rounded-xl font-bold hover:from-blue-700 hover:to-purple-700 transition-all">
                    <i class="fas fa-home mr-2"></i>Go to Homepage
                </a>
                <a asp-controller="Account" asp-action="Login" 
                   class="block bg-gray-700 text-white px-6 py-3 rounded-xl font-bold hover:bg-gray-600 transition-all">
                    <i class="fas fa-sign-in-alt mr-2"></i>Sign In
                </a>
            </div>
        </div>
    </div>
</div>
