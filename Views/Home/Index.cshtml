@model IEnumerable<EventFinder.Models.Event>

@{
    ViewData["Title"] = "EventFinder - Discover Amazing Events";
}

<!-- Hero Section -->
<div class="relative bg-gradient-to-r from-blue-600 to-purple-600 text-white overflow-hidden">
    <div class="absolute inset-0">
        <svg class="absolute left-0 bottom-0" viewBox="0 0 1440 320">
            <path fill="currentColor" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,170.7C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>
    <div class="relative max-w-7xl mx-auto py-20 px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl md:text-6xl font-extrabold mb-6 animate-fade-in">
            Discover Events
            <span class="block text-yellow-300">Near You</span>
        </h1>
        <p class="text-xl md:text-2xl mb-10 text-blue-100 max-w-3xl mx-auto">
            Find local events, meet amazing people, and create unforgettable memories
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-action="Create"
               class="bg-white text-blue-600 px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transform hover:scale-105 transition-all duration-300 shadow-xl">
                <i class="fas fa-plus-circle mr-2"></i>Create Event
            </a>
            <a asp-action="Events"
               class="bg-transparent border-2 border-white text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-white hover:text-blue-600 transform hover:scale-105 transition-all duration-300">
                <i class="fas fa-search mr-2"></i>Browse Events
            </a>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="max-w-7xl mx-auto mt-8 px-4">
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-lg shadow-md animate-slide-down" role="alert">
            <div class="flex items-center">
                <i class="fas fa-check-circle text-green-500 mr-3 text-xl"></i>
                <p>@TempData["Success"]</p>
            </div>
        </div>
    </div>
}

<!-- Stats Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl shadow-xl p-6 transform hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center">
                <div class="bg-blue-100 rounded-full p-4">
                    <i class="fas fa-calendar-check text-blue-600 text-3xl"></i>
                </div>
                <div class="ml-4">
                    <p class="text-gray-500 text-sm">Upcoming Events</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Count()</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-6 transform hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center">
                <div class="bg-green-100 rounded-full p-4">
                    <i class="fas fa-users text-green-600 text-3xl"></i>
                </div>
                <div class="ml-4">
                    <p class="text-gray-500 text-sm">Total Attendees</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Sum(e => e.AttendeeCount)</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-6 transform hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center">
                <div class="bg-purple-100 rounded-full p-4">
                    <i class="fas fa-tags text-purple-600 text-3xl"></i>
                </div>
                <div class="ml-4">
                    <p class="text-gray-500 text-sm">Categories</p>
                    <p class="text-3xl font-bold text-gray-900">@Model.Select(e => e.Category).Distinct().Count()</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Events Section -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-gray-900 mb-4">Upcoming Events</h2>
        <p class="text-xl text-gray-600">Don't miss out on these amazing opportunities</p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-16 bg-white rounded-2xl shadow-xl">
            <i class="fas fa-calendar-times text-gray-400 text-6xl mb-4"></i>
            <h3 class="text-2xl font-bold text-gray-700 mb-2">No Events Yet</h3>
            <p class="text-gray-500 mb-6">Be the first to create an event!</p>
            <a asp-action="Create" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-blue-700 transition-colors">
                <i class="fas fa-plus-circle mr-2"></i>Create Event
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl shadow-xl overflow-hidden transform hover:-translate-y-2 transition-all duration-300">
                    <!-- Event Image/Header -->
                    <div class="h-48 bg-gradient-to-r from-blue-500 to-purple-500 relative">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title" class="w-full h-full object-cover">
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fas fa-calendar-alt text-white text-6xl opacity-50"></i>
                            </div>
                        }
                        <div class="absolute top-4 right-4">
                            <span class="bg-white/90 backdrop-blur-sm text-gray-700 px-3 py-1 rounded-full text-sm font-semibold">
                                <i class="far fa-clock mr-1"></i>@item.StartDate.ToString("MMM dd")
                            </span>
                        </div>
                    </div>

                    <!-- Event Details -->
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-3">
                            <span class="bg-blue-100 text-blue-600 px-3 py-1 rounded-full text-xs font-semibold">
                                <i class="fas fa-tag mr-1"></i>@item.Category
                            </span>
                            <span class="text-gray-500 text-sm">
                                <i class="fas fa-map-marker-alt mr-1"></i>@item.City
                            </span>
                        </div>

                        <h3 class="text-xl font-bold text-gray-900 mb-2">@item.Title</h3>
                        <p class="text-gray-600 mb-4 line-clamp-2">@item.Description</p>

                        <div class="flex items-center justify-between mb-4">
                            <div class="flex items-center text-gray-500 text-sm">
                                <i class="fas fa-user mr-1"></i>
                                <span>@item.OrganizerName</span>
                            </div>
                            <div class="flex items-center text-green-600 font-semibold">
                                <i class="fas fa-user-check mr-1"></i>
                                <span>@item.AttendeeCount going</span>
                            </div>
                        </div>

                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="block w-full text-center bg-gray-100 text-gray-700 hover:bg-blue-600 hover:text-white px-4 py-3 rounded-xl font-semibold transition-all duration-300">
                            View Details
                            <i class="fas fa-arrow-right ml-2"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- CTA Section -->
<div class="bg-gradient-to-r from-blue-600 to-purple-600 py-16 mt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-bold text-white mb-4">Ready to Host Your Own Event?</h2>
        <p class="text-xl text-blue-100 mb-8">Join our community and start sharing your events today!</p>
        <a asp-action="Create"
           class="bg-white text-blue-600 px-8 py-4 rounded-xl font-bold text-lg hover:bg-gray-100 transform hover:scale-105 transition-all duration-300 shadow-xl inline-block">
            <i class="fas fa-plus-circle mr-2"></i>Get Started Now
        </a>
    </div>
</div>