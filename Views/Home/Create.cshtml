@model EventFinder.Models.Event

@{
    ViewData["Title"] = "Create New Event";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-12">
        <div class="bg-gradient-to-r from-blue-600 to-purple-600 inline-block p-4 rounded-2xl shadow-xl mb-6">
            <i class="fas fa-plus-circle text-white text-4xl"></i>
        </div>
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Create New Event</h1>
        <p class="text-xl text-gray-600">Share your amazing event with the community</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
        <form asp-action="Create" method="post" class="p-8">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-6 p-4 bg-red-50 rounded-lg" role="alert"></div>

            <!-- Basic Info Section -->
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
                    <i class="fas fa-info-circle text-blue-600 mr-2"></i>Basic Information
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Title -->
                    <div class="md:col-span-2">
                        <label asp-for="Title" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-heading text-gray-400"></i>
                            </div>
                            <input asp-for="Title" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="e.g., Tech Meetup 2024" />
                        </div>
                        <span asp-validation-for="Title" class="text-sm text-red-500"></span>
                    </div>

                    <!-- Category -->
                    <div>
                        <label asp-for="Category" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-tag text-gray-400"></i>
                            </div>
                            <select asp-for="Category" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="">Select a category</option>
                                <option value="Technology">💻 Technology</option>
                                <option value="Music">🎵 Music</option>
                                <option value="Sports">⚽ Sports</option>
                                <option value="Food">🍔 Food & Drink</option>
                                <option value="Arts">🎨 Arts & Culture</option>
                                <option value="Business">📊 Business</option>
                                <option value="Education">📚 Education</option>
                                <option value="Charity">❤️ Charity</option>
                            </select>
                        </div>
                        <span asp-validation-for="Category" class="text-sm text-red-500"></span>
                    </div>

                    <!-- Organizer -->
                    <div>
                        <label asp-for="OrganizerName" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-user text-gray-400"></i>
                            </div>
                            <input asp-for="OrganizerName" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="Your name or organization" />
                        </div>
                        <span asp-validation-for="OrganizerName" class="text-sm text-red-500"></span>
                    </div>
                </div>
            </div>

            <!-- Date & Time Section -->
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
                    <i class="fas fa-clock text-blue-600 mr-2"></i>Date & Time
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Start Date -->
                    <div>
                        <label asp-for="StartDate" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-calendar-alt text-gray-400"></i>
                            </div>
                            <input asp-for="StartDate" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" type="datetime-local" />
                        </div>
                        <span asp-validation-for="StartDate" class="text-sm text-red-500"></span>
                    </div>

                    <!-- End Date -->
                    <div>
                        <label asp-for="EndDate" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-calendar-check text-gray-400"></i>
                            </div>
                            <input asp-for="EndDate" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" type="datetime-local" />
                        </div>
                        <span asp-validation-for="EndDate" class="text-sm text-red-500"></span>
                    </div>
                </div>
            </div>

            <!-- Location Section -->
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
                    <i class="fas fa-map-marker-alt text-blue-600 mr-2"></i>Location
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Address -->
                    <div class="md:col-span-2">
                        <label asp-for="Address" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-map-pin text-gray-400"></i>
                            </div>
                            <input asp-for="Address" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="123 Main St" />
                        </div>
                        <span asp-validation-for="Address" class="text-sm text-red-500"></span>
                    </div>

                    <!-- City -->
                    <div>
                        <label asp-for="City" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-city text-gray-400"></i>
                            </div>
                            <input asp-for="City" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="San Francisco" />
                        </div>
                        <span asp-validation-for="City" class="text-sm text-red-500"></span>
                    </div>

                    <!-- Country -->
                    <div>
                        <label asp-for="Country" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-globe text-gray-400"></i>
                            </div>
                            <input asp-for="Country" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="USA" />
                        </div>
                        <span asp-validation-for="Country" class="text-sm text-red-500"></span>
                    </div>
                </div>

                <!-- Map Coordinates (Hidden for now, can add map picker later) -->
                <div class="mt-4 p-4 bg-blue-50 rounded-xl">
                    <p class="text-sm text-blue-600">
                        <i class="fas fa-info-circle mr-1"></i>
                        Coordinates will be automatically set based on address (coming soon)
                    </p>
                </div>
            </div>

            <!-- Description Section -->
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
                    <i class="fas fa-align-left text-blue-600 mr-2"></i>Event Details
                </h2>

                <div>
                    <label asp-for="Description" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                    <textarea asp-for="Description" rows="6" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="Tell people about your event... what to expect, what to bring, etc."></textarea>
                    <span asp-validation-for="Description" class="text-sm text-red-500"></span>
                </div>
            </div>

            <!-- Image Section -->
            <div class="mb-8">
                <h2 class="text-xl font-bold text-gray-900 mb-6 pb-2 border-b border-gray-200">
                    <i class="fas fa-image text-blue-600 mr-2"></i>Event Image
                </h2>

                <div>
                    <label asp-for="ImageUrl" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-link text-gray-400"></i>
                        </div>
                        <input asp-for="ImageUrl" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" placeholder="https://example.com/image.jpg" />
                    </div>
                    <p class="text-sm text-gray-500 mt-2">Leave empty for default event image</p>
                    <span asp-validation-for="ImageUrl" class="text-sm text-red-500"></span>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
                <a asp-action="Index" class="px-6 py-3 border border-gray-300 rounded-xl text-gray-700 hover:bg-gray-50 transition-colors font-semibold">
                    Cancel
                </a>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl hover:from-blue-700 hover:to-purple-700 transition-all font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                    <i class="fas fa-check-circle mr-2"></i>Create Event
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Auto-fill coordinates later
        document.addEventListener('DOMContentLoaded', function() {
            // Future: Add map picker
        });
    </script>
}